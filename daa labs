# 2. Heap Sort

def heapify(arr, n, i):
    largest = i
    left = 2*i + 1
    right = 2*i + 2

    if left < n and arr[left] > arr[largest]:
        largest = left

    if right < n and arr[right] > arr[largest]:
        largest = right

    if largest != i:
        arr[i], arr[largest] = arr[largest], arr[i]
        heapify(arr, n, largest)

def heap_sort(arr):
    n = len(arr)

    for i in range(n//2 - 1, -1, -1):
        heapify(arr, n, i)

    for i in range(n-1, 0, -1):
        arr[i], arr[0] = arr[0], arr[i]
        heapify(arr, i, 0)

arr = list(map(int, input("Enter elements: ").split()))
heap_sort(arr)
print("Sorted:", arr)

# 3. Binary Search (Recursive + Iterative)

def binary_search_rec(arr, low, high, key):
    if low <= high:
        mid = (low + high)//2
        if arr[mid] == key:
            return mid
        elif arr[mid] > key:
            return binary_search_rec(arr, low, mid-1, key)
        else:
            return binary_search_rec(arr, mid+1, high, key)
    return -1

def binary_search_itr(arr, key):
    low, high = 0, len(arr)-1
    while low <= high:
        mid = (low + high)//2
        if arr[mid] == key:
            return mid
        elif arr[mid] > key:
            high = mid - 1
        else:
            low = mid + 1
    return -1

arr = sorted(list(map(int, input("Enter sorted array: ").split())))
key = int(input("Enter key: "))
print("Recursive:", binary_search_rec(arr, 0, len(arr)-1, key))
print("Iterative:", binary_search_itr(arr, key))

# 4. Quick Sort

def partition(arr, low, high):
    pivot = arr[high]
    i = low - 1
    for j in range(low, high):
        if arr[j] < pivot:
            i += 1
            arr[i], arr[j] = arr[j], arr[i]
    arr[i+1], arr[high] = arr[high], arr[i+1]
    return i+1

def quick_sort(arr, low, high):
    if low < high:
        pi = partition(arr, low, high)
        quick_sort(arr, low, pi-1)
        quick_sort(arr, pi+1, high)

arr = list(map(int, input("Enter elements: ").split()))
quick_sort(arr, 0, len(arr)-1)
print("Sorted:", arr)

# 5 Job Sequencing (Reduced Version)

def job_sequencing(jobs):
    # Sort by profit (descending)
    jobs.sort(key=lambda x: x[2], reverse=True)

    n = len(jobs)
    slots = [False] * n
    result = [''] * n
    total_profit = 0

    for job_id, deadline, profit in jobs:
        for j in range(min(n, deadline) - 1, -1, -1):
            if not slots[j]:
                slots[j] = True
                result[j] = job_id
                total_profit += profit
                break

    print("Selected Jobs:", end=" ")
    for job in result:
        if job:
            print(job, end=" ")
    print("\nTotal Profit:", total_profit)


